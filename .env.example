# ── LLM Provider ──────────────────────────────────────────────────────────────
# Set one provider key. The backend picks GROQ first, then GEMINI, then OPENAI.
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Model / embedding settings
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── Database ──────────────────────────────────────────────────────────────────
# Use either DATABASE_URL or SUPABASE_DB_URL.
# If both are set, DATABASE_URL wins.
DATABASE_URL=
SUPABASE_DB_URL=

# ── CORS / Frontend ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173
VITE_API_URL=http://localhost:8000

# ── OCR ───────────────────────────────────────────────────────────────────────
TESSERACT_CMD=/usr/bin/tesseract

# ── Concurrency / Limits ──────────────────────────────────────────────────────
MAX_PARALLEL_DOCUMENTS=4
MAX_PARALLEL_OCR=2
MAX_PARALLEL_LLM=4
MAX_FILES_PER_REQUEST=8
MAX_FILE_SIZE_BYTES=10485760
API_TIMEOUT_SECONDS=20
OCR_TIMEOUT_SECONDS=30

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_TOP_K=5
GROUNDED_SUMMARY_MAX_TOKENS=350

# ── India-specific ────────────────────────────────────────────────────────────
USD_TO_INR=84.0
