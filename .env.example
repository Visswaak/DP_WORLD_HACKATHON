# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for LLM extraction and RAG. Without this, the system falls back to
# regex extraction and deterministic summaries.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── Database ──────────────────────────────────────────────────────────────────
# Required for analysis persistence and RAG retrieval.
# The Postgres server must have the pgvector extension installed for RAG to work.
# Without DATABASE_URL, analyses are returned but not saved.
DATABASE_URL=postgresql+psycopg://customs_user:customs_pass@db:5432/customs_ai

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins. Must be set in production.
ALLOWED_ORIGINS=http://localhost:5173

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL the browser uses to reach the backend API. Must be set at build time.
VITE_API_URL=http://localhost:8000

# ── OCR ───────────────────────────────────────────────────────────────────────
# Full path to the Tesseract binary. Required if Tesseract is not on PATH.
# In Docker this is pre-configured to /usr/bin/tesseract.
TESSERACT_CMD=/usr/bin/tesseract

# ── Concurrency ───────────────────────────────────────────────────────────────
MAX_PARALLEL_DOCUMENTS=4
MAX_PARALLEL_OCR=2
MAX_PARALLEL_LLM=4
MAX_FILES_PER_REQUEST=8
MAX_FILE_SIZE_BYTES=10485760   # 10 MB
API_TIMEOUT_SECONDS=20
OCR_TIMEOUT_SECONDS=30

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_TOP_K=5
GROUNDED_SUMMARY_MAX_TOKENS=350

# ── India-specific ────────────────────────────────────────────────────────────
# USD to INR exchange rate used for indicative duty estimates.
# Update weekly to match CBIC's notified rate.
USD_TO_INR=84.0
